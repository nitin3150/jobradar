%% ============================================================
%% JobRadar Backend Pipeline Architecture
%% Source: backend/app/{pipeline,api,scheduler}.py
%% ============================================================

graph LR

    %% ------------------------------------------------------------
    %% Triggers: scheduler (left) and HTTP API (top-left)
    %% ------------------------------------------------------------
    subgraph SCHED["APScheduler — start_scheduler in appscheduler.py"]
        direction TB
        J1["daily_pipeline<br/>cron pipeline_schedule_hour EST"]
        J2["hourly_job_scraper<br/>interval — redis-overridable<br/>SCHEDULE_OPTIONS = 1,2,4,6,12,24"]
        J3["ats_discovery<br/>interval discovery_interval_hours default 24"]
        J4["review_deadline_check<br/>every 15 min"]
        J5["gmail_poll<br/>every 15 min"]
    end

    subgraph API["HTTP — apipipeline.py prefix /pipeline"]
        direction TB
        A1["POST /pipeline/run"]
        A2["POST /pipeline/discover"]
        A3["GET,PUT /pipeline/schedule"]
        A4["GET /pipeline/status"]
    end

    %% ------------------------------------------------------------
    %% Three pipelines (middle band)
    %% ------------------------------------------------------------
    subgraph LG["Daily LangGraph — apppipelinegraph.py + nodes"]
        direction LR
        LGSTART([START]):::io
        N1["funding_detector<br/>run_all_scrapers yc crunchbase<br/>sec techcrunch twitter..."]
        N2["enrichment<br/>fetch website + meta<br/>Apify twitter hiring signals"]
        N3["scorer<br/>LiteLLM nvidia to groq<br/>score 0 to 100 and likely_roles"]
        N4["save<br/>upsert Company<br/>redis dedup by slug + funding_date"]
        LGEND([END]):::io
        LGSTART --> N1 --> N2 --> N3 --> N4 --> LGEND
    end

    subgraph JSP["Hourly Job Scraper — apppipelinejobs.py"]
        direction TB
        H1["SELECT companies<br/>WHERE ats_type IS NOT NULL"]
        H2["Phase 1 PARALLEL fetch<br/>async gather + Semaphore 10<br/>Ashby to Lever to Greenhouse"]
        H3["Phase 2 SEQUENTIAL<br/>URL dedup to title prefilter<br/>to LLM fit_score to threshold gate"]
        H4["INSERT Job<br/>status IN_REVIEW<br/>deadline now + review_window_hours"]
        H1 --> H2 --> H3 --> H4
    end

    subgraph DISC["Daily Discovery — apppipelinediscovery.py"]
        direction TB
        D1["Build site: queries<br/>role x board x domain"]
        D2["search_urls<br/>serper to playwright to apify"]
        D3["extract_slugs<br/>per-board regex<br/>filter reserved segments"]
        D4["INSERT Company<br/>source ats_discovery<br/>idempotent skip if exists"]
        D1 --> D2 --> D3 --> D4
    end

    subgraph LIFE["15-min Review Sweep"]
        direction TB
        L1["UPDATE Job<br/>WHERE review_deadline lt now<br/>to approved or rejected"]
        L2["RPUSH apply_queue<br/>job_id json approved only"]
        L1 --> L2
    end

    %% ------------------------------------------------------------
    %% Data stores & downstream consumers
    %% ------------------------------------------------------------
    PG[("PostgreSQL<br/>Company + Job + Application<br/>qa_bank + Resume + Preferences")]
    RD[("Redis<br/>seen companies<br/>config job_fetch_interval_hours<br/>apply_queue")]
    APPLY([apply_worker<br/>fills ATS forms<br/>sends outreach emails])
    GMAIL(Gmail connector<br/>poll replies into Application)

    %% ------------------------------------------------------------
    %% Edges
    %% ------------------------------------------------------------
    J1 --> LG
    J2 --> JSP
    J3 --> DISC
    J4 --> LIFE
    J5 --> GMAIL

    A1 --> LG
    A2 --> DISC
    A3 -->|"reschedule job"| J2

    N4 --> PG
    N4 -.->|"is_duplicate<br/>mark_seen"| RD
    H4 --> PG
    D4 --> PG

    PG -.->|"ATS-enabled rows"| H1
    D4 -.->|"grows company set"| H1

    L2 --> RD
    RD --> APPLY
    GMAIL --> PG

    %% ------------------------------------------------------------
    %% Styles
    %% ------------------------------------------------------------
    classDef sched fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef api fill:#dbeafe,stroke:#2563eb,color:#1e3a8a
    classDef io fill:#ffffff,stroke:#475569,color:#0f172a
    classDef lang fill:#ede9fe,stroke:#7c3aed,color:#4c1d95
    classDef job fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef disc fill:#fce7f3,stroke:#db2777,color:#831843
    classDef life fill:#e0f2fe,stroke:#0284c7,color:#0c4a6e
    classDef store fill:#f1f5f9,stroke:#475569,color:#0f172a
    classDef ext fill:#fff7ed,stroke:#ea580c,color:#7c2d12

    class J1,J2,J3,J4,J5 sched
    class A1,A2,A3,A4 api
    class N1,N2,N3,N4 lang
    class H1,H2,H3,H4 job
    class D1,D2,D3,D4 disc
    class L1,L2 life
    class PG,RD store
    class APPLY,GMAIL ext

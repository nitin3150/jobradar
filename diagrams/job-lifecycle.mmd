%% ============================================================
%% JobRadar: single-job lifecycle sequence diagram
%% Story: Lindgren AI · ashby · "Senior ML Engineer"
%% ============================================================

sequenceDiagram
    autonumber
    actor User as Reviewer
    participant Sched as APScheduler
    participant Disc as Discovery<br/>(daily)
    participant Src as Pipeline/Jobs<br/>(hourly)
    participant At as Ashby API
    participant LLM as LiteLLM<br/>(nvidia → groq)
    participant PG as Postgres
    participant RD as Redis
    participant AW as ApplyWorker<br/>(docker svc)
    participant Pw as Playwright
    participant QA as QABank
    participant Gmail as Gmail connector<br/>(15-min poll)

    %% ─────────── Phase 0: yesterday's discovery ───────────
    Note over Disc,PG: Phase 0 — yesterday, daily ats_discovery run
    Disc->>At: site:jobs.ashbyhq.com "AI Engineer"
    Disc->>Disc: regex extract slug = "lindgren"
    Disc->>PG: INSERT Company(<br/>ats_type=ashby, ats_slug=lindgren,<br/>source=ats_discovery)

    %% ─────────── Phase 1: hourly scrape creates the Job ───────────
    Note over Src,LLM: Phase 1 — next hourly tick, run_job_scrape_pipeline
    Src->>PG: SELECT companies WHERE ats_type IS NOT NULL
    Src->>At: GET /posting-api/job-board/lindgren
    At-->>Src: jobs[] [title, jobUrl, descriptionHtml]
    Src->>Src: URL dedup → title substring "ml engineer" ✓
    Src->>LLM: score_job(title, jd_text[:3000])<br/>via CANDIDATE_PROFILE prompt
    LLM-->>Src: {"score": 0.92, "reasoning": "Strong match"}
    Src->>PG: INSERT Job(<br/>title="Senior ML Engineer", url,<br/>ai_fit_score=0.92, status=IN_REVIEW,<br/>review_deadline=now+2h) + commit

    %% ─────────── Phase 2: approval path ───────────
    Note over User,RD: Phase 2 — job now in review queue

    alt Manual approval (UIT path)
        User->>Src: GET /api/jobs?status=in_review  (frontend)
        Src-->>User: JobListResponse (page of pending)
        User->>Src: POST /api/jobs/{id}/approve
        Src->>PG: UPDATE Job SET status=APPROVED  + commit
        Src->>RD: RPUSH apply_queue {"job_id": str(id)}
    else Auto-approve on review-window expiry
        Sched->>PG: UPDATE Job SET status=APPROVED<br/>WHERE status=IN_REVIEW<br/>AND review_deadline < now
        Sched->>RD: RPUSH apply_queue {"job_id": str(id)}
    else Auto-reject on review-window expiry
        Sched->>PG: UPDATE Job SET status=REJECTED<br/>WHERE ... deadline < now
        Note right of RD: no enqueue
    end

    %% ─────────── Phase 3: apply worker fills the form ───────────
    Note over AW,QA: Phase 3 — apply_worker BLPOP dequeues
    AW->>RD: BLPOP apply_queue (timeout=5s)
    RD-->>AW: {"job_id": str(id)}
    AW->>PG: SELECT Job WHERE id=UUID(job_id)
    PG-->>AW: row (status=APPROVED)
    AW->>PG: SELECT Resume rows (tokenize tags)
    AW->>PG: return absolute filesystem path of winner
    AW->>Pw: page.goto(job.url, wait_until=networkidle)
    Pw->>At: GET job posting HTML
    At-->>Pw: page DOM
    Pw->>Pw: click "Apply" if button present
    AW->>Pw: attach_resume(page, path)<br/>3-pass scan of <input type=file>
    AW->>Pw: extract_form_fields(page)<br/>iterates <label>, resolves for/nextElement
    Pw-->>AW: [{label, selector, input_type}]

    loop per form field
        AW->>QA: SELECT * FROM qa_bank WHERE answer IS NOT NULL
        alt rapidfuzz score ≥ 0.75
            AW->>QA: match by token_set_ratio
        else LiteLLM confidence ≥ 0.75
            AW->>LLM: pass-2 semantic match prompt
            LLM-->>AW: {"match_index": i, "confidence": 0.91}
        else no match
            Note right of AW: label goes to unknown_fields[]
        end
    end

    alt any unknown field
        AW->>PG: INSERT QABankEntry(question_pattern=label.lower(), answer=NULL)
        AW->>PG: UPDATE Job SET status=FLAGGED  + commit
        Note right of AW: return — does NOT re-queue
    else all matched
        loop per matched pair
            AW->>Pw: fill_field(page, field, qa_entry.answer)
            AW->>PG: qa_entry.times_used += 1<br/>last_used_at = now()
        end
        AW->>Pw: click submit button → wait networkidle
        AW->>Pw: page.screenshot({path: "screenshots/<job_id>.png"})
        AW->>PG: INSERT Application(<br/>job_id, screenshot_path,<br/>status=SUBMITTED)
        AW->>PG: UPDATE Job SET status=APPLIED  + commit
    end

    Note over AW: back to BLPOP loop

    %% ─────────── Phase 4: gmail reply ───────────
    Note over Gmail: Phase 4 — days/weeks later, recruiter replies
    Gmail->>Gmail: poll threads matching settings.gmail_label
    Gmail->>LLM: classify reply (interview/reject/offer/ghost)
    LLM-->>Gmail: {bucket, confidence}
    Gmail->>PG: UPDATE Application SET status,<br/>gmail_thread_id, last_email_at,<br/>notes  + commit
    PG-->>User: shows on ApplicationTracker (GET /api/applications)

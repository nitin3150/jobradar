[TEMPLATE]
# JobRadar env. The Postgres connection lives on Supabase - the local
# postgres Docker service that used to back this app has been
# retired per the operator's preference for a fully cloud-hosted setup.
# See README and docs/project-overview.md 7.3 for the walk-through.

# LLM Provider (default: groq FREE; alternatives: ollama, gemini, anthropic, openrouter)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Ollama (FREE, local - no key)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# Google Gemini (free tier)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=

# Anthropic Claude (paid)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=

# OpenRouter
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3-8b-instruct
# OPENROUTER_API_KEY=

# Other Services
APIFY_API_KEY=

# Supabase (production target)
# 1. Create a project at https://database.new
# 2. Settings -> Database -> Connection string -> URI
#    Pick "Transaction pooler" (port 6543). Replace postgresql:// with
#    postgresql+asyncpg://. asyncpg disables prepared statements
#    automatically when env.py sees pooler.supabase.com or port 6543.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# 3. Settings -> API -> Project URL  (server-only)
SUPABASE_URL=https://PROJECT_REF.supabase.co

# 4. Settings -> API -> service_role secret  (server-only)
SUPABASE_SERVICE_ROLE_KEY=

# 5. Optional: anon key for future public reads (do NOT use for writes)
# SUPABASE_ANON_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# Scheduler
PIPELINE_SCHEDULE_HOUR=8
PIPELINE_SCHEDULE_TIMEZONE=America/New_York

# Boards runner — the lookback window for ``pipeline/nodes/jobs_boards/runner.py``.
# Default 168h = 1 week (matches the cadence the LangGraph funding/OSS schedulers use).
# Override at deploy time:
#   BOARDS_DELTA_HOURS=24   # last day (chatty daily scenario)
#   BOARDS_DELTA_HOURS=720  # last month (catch-up after a long downtime)
# Read once at module-import — a worker restart picks up the new value.
# Scope of the override (intentionally non-uniform to preserve legacy cron scripts):
#   * Direct ``run_all(...)`` call without explicit delta_hours → env value.
#   * ``python -m runner`` (no flag) AND env set                 → env value.
#   * ``python -m runner`` (no flag) AND env unset               → 1h (LEGACY, kept).
#   * Any explicit ``--delta-hours`` flag or explicit caller-supplied
#     delta_hours (the FastAPI ``?delta_hours=`` route, the
#     ``--delta-hours`` CLI flag, ``routes/pipeline.py::discover``)
#     → that explicit value (env has no effect).
# BOARDS_DELTA_HOURS=168

# ── LLM Provider ──
# Default: "groq" (FREE — 30 req/min, no credit card needed)
# Options: groq, ollama, gemini, anthropic, openrouter

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ── Groq (FREE tier — recommended) ──
# Sign up & get key: https://console.groq.com/keys
# Free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=

# ── Ollama (FREE, local — no key needed) ──
# Install: curl -fsSL https://ollama.ai/install.sh | sh && ollama pull llama3
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# ── Google Gemini (FREE tier: 15 req/min, 1M tokens/day) ──
# Get key: https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=

# ── Anthropic Claude (paid) ──
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=

# ── OpenRouter (some free models) ──
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3-8b-instruct
# OPENROUTER_API_KEY=

# ── Other Services ──
APIFY_API_KEY=

# ── Database ──
DATABASE_URL=postgresql+asyncpg://fundingradar:secret@localhost:5432/fundingradar
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=secret

# ── Scheduler ──
PIPELINE_SCHEDULE_HOUR=8
PIPELINE_SCHEDULE_TIMEZONE=America/New_York

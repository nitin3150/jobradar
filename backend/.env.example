# ── Backend (standalone) ──────────────────────────────────────────────
# Copy this file to `backend/.env` and fill in the secrets. The full
# `.env.example` at the repo root has more variables for the docker
# pipeline (LLM providers, scheduler knobs, etc.) — this file covers
# just what you need to run `python main.py` against a local Postgres +
# Redis.
#
# All variables are documented in `backend/README.md`.

# ── Storage ──
DATABASE_URL=postgresql+asyncpg://fundingradar:secret@localhost:5432/fundingradar
REDIS_URL=redis://localhost:6379/0

# ── LLM scoring (used by /api/scan/* via services.scoring_service) ──
# Set at least one of these. When both are set, NVIDIA is tried first and
# Groq acts as the fallback. Each opportunity costs at most len(providers)
# × 2 LLM calls (1 retry on transient errors per provider) before the
# scoring pipeline logs a WARN and silently drops the opportunity.
NVIDIA_API_KEY=
GROQ_API_KEY=

# Optional overrides for the OpenAI-compatible endpoints + model names.
# Defaults: NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1,
#           NVIDIA_MODEL=meta/llama-3.1-70b-instruct,
#           GROQ_BASE_URL=https://api.groq.com/openai/v1,
#           GROQ_MODEL=llama-3.3-70b-versatile.
# NVIDIA_BASE_URL=
# NVIDIA_MODEL=
# GROQ_BASE_URL=
# GROQ_MODEL=

# NVIDIA requests-per-minute ceiling. The default tier NVIDIA NIM key
# is throttled at 40 RPM; without this guard the GHA boards-scan
# workflow hits 429s on every opportunity (visible in
# ``boards-scan`` logs as ``all LLM providers failed; last error
# type=RateLimitError``). The rate limiter is a token bucket sized
# at ``capacity == NVIDIA_RPM`` and refilled at ``NVIDIA_RPM / 60``
# tokens/second, so a fully-drained bucket recovers in 60s.
# Set NVIDIA_RPM=0 to disable (use case: a higher-tier key, or an
# interactive one-off bulk rescan that wants to push the throttle
# out of the way). 0 / negative / malformed values raise at boot.
# NOTE: with the default 40 RPM, a boards-scan that scrapes 300+
# opportunities will take ~7-8 min to score (was ~2 min unscored);
# the boards-scan GHA workflow's timeout-minutes needs to be ≥ 10
# to give the cron a margin for scrape + score + DB upsert, or the
# run will be killed mid-scoring. Raise it on the workflow file or
# set NVIDIA_RPM=0 for the cron if you need sub-2-min runs.
# NVIDIA_RPM=40

# ── GitHub & OSS scraper ───────────────────────────────────────────────
# Optional but recommended for production. With ``GITHUB_TOKEN`` unset,
# the good-first-issues scraper is rate-limited to 60 req/IP/hour; with
# any PAT, that jumps to 5,000 req/hour and you get per-user policies.
#
# Token shape:
#   • Classic PAT (ghp_…):        tick the ``public_repo`` scope.
#   • Fine-grained PAT (github_pat_…): in "Permissions", grant
#     "Metadata: Read" + "Issues: Read" and select
#     "Public Repositories (read-only)". Fine-grained PATs have no
#     ``public_repo`` scope.
#
# Token is read once at import time. To rotate, restart the process.
# NOTE: GitHub's Search API has a secondary 30 req/min cap, so a
# fast burst within a single minute is still throttled even with a token.
# The in-process lru_cache in github_issues.py amortises most scheduler
# runs to one call per (language, day), but a cold-process startup with
# N languages can still burst-trip the 30/min cap.
#
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=
